# Copy to .env in the repository root

# ── Shared (read by both api/ and bot/) ──────────────────────────────────
BOT_TOKEN=                        # bot token from @BotFather

# ── api/ ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./api/data/app.db

# Telegram developer IDs (get via: @userinfobot)
DEV_TELEGRAM_ID_1=
DEV_TELEGRAM_ID_2=
DEV_TELEGRAM_ID_3=

# GitHub webhook: Settings > Webhooks > Secret
GITHUB_WEBHOOK_SECRET=

# Chat ID for GitHub alerts (negative number for groups, e.g. -1001234567890)
TELEGRAM_ALERT_CHAT_ID=

# Chat ID for daily standup reports
TELEGRAM_REPORT_CHAT_ID=

# ── bot/ ──────────────────────────────────────────────────────────────
# URL of deployed frontend (must be HTTPS for Telegram Mini App)
WEBAPP_URL=https://<your-space>.hf.space

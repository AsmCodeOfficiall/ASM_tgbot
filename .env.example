# Скопіюй у .env у корені репо

# ── Спільні (читають і api/, і bot/) ──────────────────────────────────
BOT_TOKEN=                        # токен бота з @BotFather

# ── api/ ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./api/data/app.db

# ID розробників у Telegram (отримати: @userinfobot)
DEV_TELEGRAM_ID_1=
DEV_TELEGRAM_ID_2=
DEV_TELEGRAM_ID_3=

# GitHub webhook: Settings > Webhooks > Secret
GITHUB_WEBHOOK_SECRET=

# ID чату для GitHub-алертів (негативне число для груп, напр. -1001234567890)
TELEGRAM_ALERT_CHAT_ID=

# ID чату для щоденного зведення стендапу
TELEGRAM_REPORT_CHAT_ID=

# ── bot/ ──────────────────────────────────────────────────────────────
# URL задеплоєного фронтенду (має бути HTTPS для Telegram Mini App)
WEBAPP_URL=https://<your-space>.hf.space
